# ============================================================
# AMOSKYS .gitignore — Organized & Deduplicated
# ============================================================

# ---- Python Bytecode & Caches ----
__pycache__/
*.py[codz]
*$py.class
*.so
.Python

# ---- Virtual Environments ----
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
amoskys-venv/

# ---- Package Distribution ----
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---- PyInstaller ----
*.manifest
*.spec

# ---- Installer Logs ----
pip-log.txt
pip-delete-this-directory.txt

# ---- Testing & Coverage ----
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ---- Type Checkers & Linters ----
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/

# ---- Translations ----
*.mo
*.pot

# ---- IDE & Editor ----
.vscode/
.idea/
*.swp
*.swo
*~
~$*
.~lock.*
.spyderproject
.spyproject
.ropeproject
.cursorignore
.cursorindexingignore

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride

# ---- AMOSKYS Runtime Data ----
data/
!data/.gitkeep
logs/
!logs/.gitkeep

# ---- AMOSKYS Lab (local dev) ----
.amoskys_lab/
.local_backup/

# ---- Database Files ----
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
db.sqlite3-journal

# ---- Certificates (generated, not committed) ----
certs/*.key
certs/*.crt
certs/*.csr
certs/*.pem
certs/ca.srl

# ---- Environment & Secrets ----
.env
.env.*
.envrc
!.env.example
!.env.template

# ---- Logs ----
*.log
*.pid
*.sock

# ---- Docker ----
# docker-compose overrides stay, logs don't

# ---- Backups ----
backup_before_cleanup/
backup_*/
backups/

# ---- Assessment Reports (generated) ----
assessment_report_*.json
final_assessment*.json
*_assessment*.json
bandit-report.json
safety-report.json
security-*.json

# ---- LibreOffice / Office Temp Files ----
lu*.tmp

# ---- gRPC Proto Stubs ----
agents/*/proto_stubs/

# ---- Config Overrides (local only) ----
config/local.yaml
config/*.local.*

# ---- Runtime Artifacts ----
*.lock
activate_env.sh

# ---- Generated Doc Files ----
docs/_build/
/site

# ---- Stale Root Files ----
FRAMEWORK_SUMMARY.txt
GIT_COMMIT_MESSAGE.txt

# ---- ML Pipeline Artifacts ----
data/ml_pipeline/

# ---- Misc ----
.pdm-python
.pdm-build/
.pixi
__pypackages__/
celerybeat-schedule
celerybeat.pid
*.sage.py
.abstra/
marimo/_static/
marimo/_lsp/
__marimo__/
.pypirc
.scrapy
instance/
.webassets-cache
.ipynb_checkpoints
profile_default/
ipython_config.py
.pybuilder/
target/
