# ============================================================
# AMOSKYS .gitignore — Organized & Deduplicated
# ============================================================

# ---- Python Bytecode & Caches ----
__pycache__/
*.py[codz]
*$py.class
*.so
.Python

# ---- Virtual Environments ----
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
amoskys-venv/

# ---- Package Distribution ----
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ---- PyInstaller ----
*.manifest
*.spec

# ---- Installer Logs ----
pip-log.txt
pip-delete-this-directory.txt

# ---- Testing & Coverage ----
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py.cover
.hypothesis/
.pytest_cache/
cover/

# ---- Type Checkers & Linters ----
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/

# ---- Translations ----
*.mo
*.pot

# ---- IDE & Editor ----
.vscode/
.idea/
*.swp
*.swo
*~
~$*
.~lock.*
.spyderproject
.spyproject
.ropeproject
.cursorignore
.cursorindexingignore

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride

# ---- AMOSKYS Runtime Data ----
data/
logs/
!logs/.gitkeep

# ---- AMOSKYS Lab (local dev) ----
.amoskys_lab/
.local_backup/

# ---- LLM Model Files (never committed) ----
*.gguf
*.ggml
*.safetensors

# ---- Database Files ----
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
db.sqlite3-journal

# ---- Certificates (generated, not committed) ----
certs/*.key
certs/*.crt
certs/*.csr
certs/*.pem
certs/ca.srl
certs/agents/*.ed25519

# ---- Environment & Secrets ----
.env
.env.*
.envrc
!.env.example
!.env.template
.dev_secret_key

# ---- Logs ----
*.log
*.pid
*.sock

# ---- Docker ----
# docker-compose overrides stay, logs don't

# ---- Backups ----
backup_before_cleanup/
backup_*/
backups/

# ---- Assessment Reports (generated) ----
assessment_report_*.json
final_assessment*.json
*_assessment*.json
bandit-report.json
safety-report.json
security-*.json

# ---- LibreOffice / Office Temp Files ----
lu*.tmp

# ---- gRPC Proto Stubs ----
agents/*/proto_stubs/

# ---- Config Overrides (local only) ----
config/local.yaml
config/*.local.*

# ---- Runtime Artifacts ----
*.lock
activate_env.sh

# ---- Generated Doc Files ----
docs/_build/
/site

# ---- Red Team Exercise Data (SENSITIVE — real credentials & loot) ----
docs/AMOSKYS Research/red_team_amos_killchain/

# ---- Stale Root Files ----
FRAMEWORK_SUMMARY.txt
GIT_COMMIT_MESSAGE.txt

# ---- ML Pipeline Artifacts ----
data/ml_pipeline/

# ---- Claude Code (IDE session data) ----
.claude/

# ---- Misc ----
.pdm-python
.pdm-build/
.pixi
__pypackages__/
celerybeat-schedule
celerybeat.pid
*.sage.py
.abstra/
marimo/_static/
marimo/_lsp/
__marimo__/
.pypirc
.scrapy
instance/
.webassets-cache
.ipynb_checkpoints
profile_default/
ipython_config.py
.pybuilder/
target/
kali/.env
certs/*.key

# ---- Local-only / sensitive (never push) ----
# Any directory literally named _local/ anywhere in the tree.
# Use for session notes, credentials, infrastructure addresses
# that must not leave this machine.
_local/
**/_local/

# Explicit: session + lab credential notes
docs/_local/
**/creds.env
**/*.creds
**/*.secrets
.local.*
*.local

# MCP server config (may contain endpoint URLs / tokens)
.mcp.json

# Claude launch.json with env-injected secrets
.claude/launch.json

# ---- WordPress core (test lab target — don't commit upstream code) ----
# Our Aegis plugin IS committed at:
#   src/amoskys/agents/Web/wordpress/wp-content/plugins/amoskys-aegis/
# Everything else under wordpress/ is upstream WordPress and stays local.
src/amoskys/agents/Web/wordpress/*
!src/amoskys/agents/Web/wordpress/wp-content/
src/amoskys/agents/Web/wordpress/wp-content/*
!src/amoskys/agents/Web/wordpress/wp-content/plugins/
src/amoskys/agents/Web/wordpress/wp-content/plugins/*
!src/amoskys/agents/Web/wordpress/wp-content/plugins/amoskys-aegis/

