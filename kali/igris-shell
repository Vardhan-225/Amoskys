    parser.add_argument("--target", default="", help="Target IP")
    parser.add_argument("--ssh-user", default="", help="SSH user for target")
    parser.add_argument("--ssh-key", default="", help="SSH key for target")
    parser.add_argument("--model", default="claude-sonnet-4-20250514", help="Claude model")
    args = parser.parse_args()

    shell = IgrisRedShell(
        target=args.target,
        ssh_user=args.ssh_user,
        ssh_key=args.ssh_key,
        model=args.model,
    )
    shell.run()


if __name__ == "__main__":
    main()
