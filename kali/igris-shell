        while True:
            try:
                user_input = input(f"{C.GREEN}{C.BOLD}you РќИ {C.RESET}").strip()
            except (EOFError, KeyboardInterrupt):
                print(f"\n{C.DIM}IGRIS signing off.{C.RESET}")
                break

            if not user_input:
                continue
            if user_input.lower() in ("exit", "quit", "q"):
                print(f"{C.DIM}IGRIS signing off.{C.RESET}")
                break

            # Handle target setting
            if user_input.lower().startswith("target "):
