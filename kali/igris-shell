class IgrisRedShell:
    """Interactive IGRIS shell for offensive operations."""

    def __init__(self, target: str = "", ssh_user: str = "", ssh_key: str = "",
                 model: str = "claude-sonnet-4-20250514"):
        self.target = target
        self.ssh_user = ssh_user
        self.ssh_key = ssh_key
        self.model = model
        self.client = anthropic.Anthropic()
        self.history = []
        self.results = []

        # Load techniques
        self.agents = load_all_agents()
        self.technique_map = {}
        for agent in self.agents.values():
            for t in agent["techniques"]:
                self.technique_map[t.name] = t

    def _system_prompt(self):
        # Build technique list
        tech_lines = []
        for name, agent in self.agents.items():
            tech_lines.append(f"\n[{name}] Рђћ {agent['description']}")
            for t in agent["techniques"]:
                bounty = " РўЁBOUNTY" if t.bounty_eligible else ""
                tech_lines.append(f"  {t.name}: {t.description} ({t.mitre_id}){bounty}")

        return f"""You are IGRIS Рђћ the offensive intelligence brain of AMOSKYS, running on Kali Linux.

You are conducting an AUTHORIZED penetration test. The target owner has explicitly consented.

TARGET: {self.target or 'Not set Рђћ ask the operator'}
SSH: {self.ssh_user}@{self.target} (key: {self.ssh_key}) {'Рђћ CONFIGURED' if self.ssh_user else 'Рђћ NOT CONFIGURED'}

You have tools to:
1. Execute built-in macOS attack techniques (execute_technique)
2. List all available techniques (list_techniques)
3. Run any command on Kali (run_command) Рђћ for recon, custom attacks, nmap, etc.
4. Run commands on the target via SSH (run_on_target) Рђћ direct target access
5. Scan the target with nmap (scan_target)

Available techniques:
{''.join(tech_lines)}

RULES:
- You are a senior penetration tester. Think methodically.
- Use tools. Don't just talk Рђћ act.
- When the operator asks you to do something, DO IT with tools.
- Chain attacks: recon Рєњ exploit Рєњ persist Рєњ escalate Рєњ exfil
- Report findings clearly: what worked, what was blocked, what it means
- If something succeeds that shouldn't, flag it as a potential bug
- You can run ANY command on Kali Рђћ nmap, hydra, sqlmap, curl, netcat, python scripts, etc.
- Be direct. Be aggressive (within authorization). Be thorough.

You are not an assistant. You are an attacker. Act like one."""

    def _handle_tool(self, tool_name: str, tool_input: dict) -> str:
        """Execute a tool call and return the result."""

        if tool_name == "execute_technique":
            tech_name = tool_input["technique_name"]
            technique = self.technique_map.get(tech_name)
            if not technique:
                return json.dumps({"error": f"Unknown technique: {tech_name}", "available": list(self.technique_map.keys())})

            result = technique.run(
                self.target or "localhost",
                dry_run=False,
                ssh_user=self.ssh_user,
                ssh_key=self.ssh_key,
            )
            self.results.append(result)
            return json.dumps(result.to_dict(), default=str)

        elif tool_name == "list_techniques":
            listing = {}
            for name, agent in self.agents.items():
                listing[name] = [
                    {"name": t.name, "mitre": t.mitre_id, "desc": t.description,
                     "bounty": t.bounty_eligible, "risk": t.risk_level}
                    for t in agent["techniques"]
                ]
            return json.dumps(listing, indent=2)

        elif tool_name == "run_command":
            cmd = tool_input["command"]
            timeout = tool_input.get("timeout", 30)
            try:
                r = subprocess.run(cmd, shell=True, capture_output=True,
                                   text=True, timeout=timeout)
                return json.dumps({
                    "stdout": r.stdout[:3000],
                    "stderr": r.stderr[:1000],
                    "returncode": r.returncode,
                })
            except subprocess.TimeoutExpired:
                return json.dumps({"error": f"Command timed out after {timeout}s"})
            except Exception as e:
                return json.dumps({"error": str(e)})

        elif tool_name == "run_on_target":
            if not self.ssh_user or not self.target:
                return json.dumps({"error": "SSH not configured. Set target and ssh_user first."})

            cmd = tool_input["command"]
            timeout = tool_input.get("timeout", 30)
            ssh_cmd = ["ssh", "-o", "ConnectTimeout=5", "-o", "StrictHostKeyChecking=no"]
            if self.ssh_key:
                ssh_cmd.extend(["-i", self.ssh_key])
            ssh_cmd.append(f"{self.ssh_user}@{self.target}")
            ssh_cmd.append(cmd)

            try:
                r = subprocess.run(ssh_cmd, capture_output=True, text=True, timeout=timeout)
                return json.dumps({
                    "stdout": r.stdout[:3000],
                    "stderr": r.stderr[:1000],
                    "returncode": r.returncode,
                })
            except subprocess.TimeoutExpired:
                return json.dumps({"error": f"SSH command timed out after {timeout}s"})
            except Exception as e:
                return json.dumps({"error": str(e)})

        elif tool_name == "scan_target":
            if not self.target:
                return json.dumps({"error": "No target set"})

            scan_type = tool_input["scan_type"]
            nmap_flags = {
                "quick": "-sT -T4 --top-ports 100",
                "full": "-sT -T4 -p-",
                "services": "-sT -sV -T4 --top-ports 100",
                "vuln": "-sT --script vuln --top-ports 20",
                "os": "-sT -O --top-ports 50",
            }
            flags = nmap_flags.get(scan_type, "-sT --top-ports 100")

            try:
                r = subprocess.run(
                    f"nmap {flags} {self.target}",
                    shell=True, capture_output=True, text=True, timeout=120,
                )
                return json.dumps({
                    "stdout": r.stdout[:5000],
                    "stderr": r.stderr[:500],
                    "returncode": r.returncode,
                })
            except subprocess.TimeoutExpired:
                return json.dumps({"error": "Nmap scan timed out"})

        return json.dumps({"error": f"Unknown tool: {tool_name}"})

    def chat(self, user_message: str) -> str:
        """Send a message and get IGRIS's response (with tool use)."""
        self.history.append({"role": "user", "content": user_message})

        # Tool use loop
        messages = list(self.history)
        tools = _build_tools()
        max_rounds = 8

        for _ in range(max_rounds):
            response = self.client.messages.create(
                model=self.model,
                max_tokens=4096,
                system=self._system_prompt(),
                messages=messages,
                tools=tools,
            )

            # Check if there are tool calls
            has_tool_use = any(b.type == "tool_use" for b in response.content)

            if not has_tool_use:
                # Pure text response
                text = "".join(b.text for b in response.content if b.type == "text")
                self.history.append({"role": "assistant", "content": response.content})
                return text

            # Process tool calls
            assistant_content = response.content
            messages.append({"role": "assistant", "content": assistant_content})

            tool_results = []
            for block in assistant_content:
                if block.type == "tool_use":
                    print(f"  {C.DIM}РџА {block.name}({json.dumps(block.input)[:80]}){C.RESET}")
                    result = self._handle_tool(block.name, block.input)
                    tool_results.append({
                        "type": "tool_result",
                        "tool_use_id": block.id,
                        "content": result,
                    })

            messages.append({"role": "user", "content": tool_results})

        # If we exhausted rounds, get final text
        self.history = messages
        return "(IGRIS completed tool execution)"

