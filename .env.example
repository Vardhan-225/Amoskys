# AMOSKYS Neural Security Command Platform
# Environment Configuration Template
# Copy this file to .env and configure for your environment

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Flask secret key for session encryption (REQUIRED - generate a random 32+ char string)
SECRET_KEY=your-secure-random-secret-key-here

# Flask environment (development | production)
FLASK_ENV=production
FLASK_DEBUG=false

# Server port
FLASK_PORT=8000

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Core database (telemetry, agents, events)
DATABASE_URL=sqlite:///data/amoskys.db
# Or for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/amoskys

# Web database (users, sessions, auth)
WEB_DATABASE_URL=sqlite:///web/data/amoskys_web.db
# AMOSKYS_WEB_DB_PATH=/path/to/web/data/amoskys_web.db

# Database type (sqlite | postgresql)
AMOSKYS_DB_TYPE=sqlite

# PostgreSQL settings (if using PostgreSQL)
# AMOSKYS_DB_HOST=localhost
# AMOSKYS_DB_PORT=5432
# AMOSKYS_DB_NAME=amoskys
# AMOSKYS_DB_USER=amoskys
# AMOSKYS_DB_PASSWORD=secure-password

# Enable SQL query logging (for debugging only)
AMOSKYS_DB_ECHO=false

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Enable secure cookies (set to true in production with HTTPS)
AMOSKYS_SECURE_COOKIES=true

# Session lifetime in seconds (default: 7 days)
SESSION_LIFETIME=604800

# Password hashing cost factor (higher = more secure but slower)
BCRYPT_ROUNDS=12

# JWT secret for API tokens (if using JWT)
# JWT_SECRET_KEY=your-jwt-secret-key

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# SMTP settings for email verification and password reset
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=AMOSKYS Security Platform

# Enable development mode (prints emails to console instead of sending)
AMOSKYS_EMAIL_DEV_MODE=false

# =============================================================================
# GRPC / EVENTBUS SETTINGS
# =============================================================================

# gRPC EventBus server
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# TLS certificates for gRPC (production)
GRPC_TLS_ENABLED=true
GRPC_CA_CERT=certs/ca.crt
GRPC_SERVER_CERT=certs/server.crt
GRPC_SERVER_KEY=certs/server.key

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================

# Agent authentication token (for agent-to-server communication)
# AGENT_AUTH_TOKEN=your-agent-token

# Agent heartbeat interval in seconds
AGENT_HEARTBEAT_INTERVAL=30

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# Enable JSON formatted logs (recommended for production)
JSON_LOGS=true

# Log file path (optional, defaults to stdout)
# LOG_FILE=/var/log/amoskys/app.log

# =============================================================================
# RATE LIMITING
# =============================================================================

# Redis URL for distributed rate limiting (optional)
# REDIS_URL=redis://localhost:6379/0

# Default rate limits (requests per time period)
RATE_LIMIT_DEFAULT=100 per minute
RATE_LIMIT_AUTH=10 per minute

# =============================================================================
# MONITORING / OBSERVABILITY
# =============================================================================

# Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PORT=9090

# Sentry error tracking (optional)
# SENTRY_DSN=https://your-sentry-dsn

# =============================================================================
# NEURAL ENGINE / AI SETTINGS
# =============================================================================

# Enable neural threat detection
NEURAL_ENGINE_ENABLED=true

# Model path for ML-based detection
# ML_MODEL_PATH=/path/to/models

# =============================================================================
# CORS SETTINGS (if using separate frontend)
# =============================================================================

# Comma-separated list of allowed origins
# ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com
