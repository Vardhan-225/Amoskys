# AMOSKYS Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# LLM Backend: "ollama" (free, local, default) or "claude" (paid, API)
IGRIS_BACKEND=ollama

# Model selection
# Ollama: qwen3:8b (default), qwen2.5:14b, mistral-nemo:12b, llama3.1:8b
# Claude: claude-sonnet-4-20250514 (default)
IGRIS_MODEL=qwen3:8b

# Ollama settings
OLLAMA_HOST=http://localhost:11434

# Claude API (only needed if IGRIS_BACKEND=claude)
# ANTHROPIC_API_KEY=your-api-key-here

# Dashboard settings
# FLASK_PORT=5003
# SECRET_KEY=generate-with-python-secrets
# LOGIN_DISABLED=true
