# AMOSKYS Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# Required for IGRIS AI chatbot (Claude API)
ANTHROPIC_API_KEY=your-api-key-here

# Optional: Override LLM model
# IGRIS_LLM_MODEL=claude-sonnet-4-20250514

# Optional: Use Ollama for offline/air-gapped mode
# IGRIS_BACKEND=ollama
# OLLAMA_MODEL=llama3.1:8b

# Optional: Dashboard settings
# FLASK_PORT=5003
# SECRET_KEY=generate-with-python-secrets
# LOGIN_DISABLED=true
