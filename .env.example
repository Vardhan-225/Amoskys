# AMOSKYS Environment Configuration
# Copy to .env and fill in your values. Never commit .env to git.

# IGRIS LLM — Claude API
IGRIS_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your-api-key-here

# Dashboard settings
# FLASK_PORT=5003
# SECRET_KEY=generate-with-python-secrets
# LOGIN_DISABLED=true

# Email / SMTP (for alert notifications)
AMOSKYS_EMAIL_PASSWORD=your-smtp-password
# AMOSKYS_EMAIL_HOST=smtp.gmail.com
# AMOSKYS_EMAIL_PORT=587
# AMOSKYS_EMAIL_USER=alerts@example.com
