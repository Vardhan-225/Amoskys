[Unit]
Description=AMOSKYS DeviceDiscovery v2 - Discovery Plane Asset Mapping
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/amoskys-src
Environment="PYTHONUNBUFFERED=1"
Environment="PYTHONPATH=/home/ubuntu/amoskys-src/src"

# Agent command - using venv Python
ExecStart=/home/ubuntu/amoskys-venv/bin/python3 /home/ubuntu/device_discovery/run_agent_v2.py \
    --device-id=%H \
    --queue-path=/var/lib/amoskys/queues/device_discovery \
    --collection-interval=30 \
    --metrics-interval=60

# Restart policy
Restart=on-failure
RestartSec=10
TimeoutStartSec=120

# Resource limits (tune based on load)
MemoryMax=512M
NoNewPrivileges=yes

# Environment
Environment="AMOSKYS_AGENT=device_discovery_v2"

[Install]
WantedBy=multi-user.target
